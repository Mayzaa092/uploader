# Domain publik uploader kamu. WAJIB diisi di production (VPS/Windows/Replit/Vercel)
# supaya link yang dihasilkan selalu pakai domain ini, bukan host internal.
BASE_URL=https://uploader.mayzaa.my.id

# Port untuk server.js (VPS/Windows/Replit). Vercel mengabaikan ini.
PORT=3000

# Lokasi penyimpanan file + database JSON.
# Default: ./data (persist di VPS/Windows/Replit). Jangan diisi di Vercel.
# DATA_DIR=./data
